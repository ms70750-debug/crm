APP_ENV=local
APP_MODE=demo
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BBB_AUTH_SECRET=troque-este-valor-em-ambiente-seguro
BBB_DATA_ENCRYPTION_KEY=troque-este-valor-por-chave-forte-fora-do-git
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Runtime da API. Em Supabase, usar a DATABASE_URL do pooler transaction-mode.
DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=10
# Uso exclusivo para migrations/admin. Em Supabase, usar a DIRECT_URL do pooler session-mode.
DIRECT_URL=
REAL_DATA_MODE=false
MIGRATIONS_APPLIED=false
BACKUP_CONFIGURED=false
BACKUP_ENCRYPTION_KEY=
BACKUP_STORAGE_PROVIDER=
BACKUP_STORAGE_BUCKET=
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3
POSTGRES_RESTORE_URL=
PASSWORD_RECOVERY_BASE_URL=http://localhost:5173/redefinir-senha
AUTH_EMAIL_ENABLED=false
AUTH_EMAIL_MODE=simulate
AUTH_EMAIL_FROM=
APP_PUBLIC_URL=http://localhost:5173
RESEND_API_KEY=
CONSENT_REQUIRED=false
LOGS_MASKED=false
HTTPS_EXPECTED=false
CRITICAL_TESTS_APPROVED=false
APP_VERSION=0.1.0
MONITORING_ALERTS_ENABLED=false
MONITORING_CONTACT_CHANNEL=
VITE_API_URL=http://localhost:8000
EVOLUTION_API_MODE=simulation
EVOLUTION_API_URL=
EVOLUTION_API_TOKEN=
