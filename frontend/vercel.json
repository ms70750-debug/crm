{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "feature/real-data-readiness-2026-07-12": false
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://crm-2340.onrender.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
